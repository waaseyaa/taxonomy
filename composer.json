{
    "name": "waaseyaa/taxonomy",
    "description": "Taxonomy vocabulary and term entity types for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/access": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Taxonomy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Taxonomy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": ["Waaseyaa\\Taxonomy\\TaxonomyServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
