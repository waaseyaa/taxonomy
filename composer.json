{
    "name": "aurora/taxonomy",
    "description": "Taxonomy vocabulary and term entity types for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "aurora/entity": "@dev",
        "aurora/access": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Taxonomy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Taxonomy\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
